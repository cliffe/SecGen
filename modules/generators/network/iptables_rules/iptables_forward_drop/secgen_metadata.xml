<?xml version="1.0"?>

<generator xmlns="http://www.github/cliffe/SecGen/generator"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://www.github/cliffe/SecGen/generator">
  <name>iptables_forward_drop</name>
  <author>Tom Shaw</author>
  <module_license>GPLv3</module_license>
  <description>Generates an iptables FORWARD DROP rule string for a given source and destination.</description>

  <type>iptables_rule</type>
  <platform>linux</platform>

  <read_fact>source</read_fact>
  <read_fact>destination</read_fact>

  <default_input into="source">
    <value>10.0.0.0/24</value>
  </default_input>

  <default_input into="destination">
    <value>10.0.1.0/24</value>
  </default_input>

  <output_type>iptables_rule</output_type>

</generator>