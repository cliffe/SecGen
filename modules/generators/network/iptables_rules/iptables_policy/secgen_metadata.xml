<?xml version="1.0"?>

<generator xmlns="http://www.github/cliffe/SecGen/generator"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://www.github/cliffe/SecGen/generator">
  <name>iptables_policy</name>
  <author>Tom Shaw</author>
  <module_license>GPLv3</module_license>
  <description>Generates an iptables policy rule string, e.g. -P FORWARD DROP</description>

  <type>iptables_rule</type>
  <platform>linux</platform>

  <read_fact>chain</read_fact>
  <read_fact>policy</read_fact>

  <default_input into="chain">
    <value>FORWARD</value>
  </default_input>

  <default_input into="policy">
    <value>DROP</value>
  </default_input>
  <output_type>iptables_rule</output_type>
</generator>