<?xml version="1.0"?>

<generator xmlns="http://www.github/cliffe/SecGen/generator"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://www.github/cliffe/SecGen/generator">
  <name>network_route</name>
  <author>Tom Shaw</author>
  <module_license>GPLv3</module_license>
  <description>Generates a static route string for use in /etc/network/interfaces, e.g. 10.0.2.0/24 via 10.0.1.1 or optionally 10.0.2.0/24 via 10.0.1.1 dev eth0</description>

  <type>network_route</type>
  <platform>linux</platform>

  <read_fact>destination</read_fact>
  <read_fact>subnet_mask</read_fact>
  <read_fact>via</read_fact>
  <read_fact>dev</read_fact>

  <default_input into="subnet_mask">
    <value>255.255.255.0</value>
  </default_input>
  <output_type>network_route</output_type>
</generator>