<% require 'json'
	 require 'securerandom'

	 if self.accounts.empty?
		 abort('Sorry, you need to provide an account')
	 end

	 $first_account = JSON.parse(self.accounts.first)
	 $main_user = $first_account['username'].to_s
	 $user_password = $first_account['password'].to_s

	 # IP addresses from datastore - must match scenario.xml index comments
	 $gateway_lan_ip    = self.IP_addresses[0]
	 $desktop_ip        = self.IP_addresses[1]
	 $gateway_dmz_ip    = self.IP_addresses[2]
	 $webserver_ip      = self.IP_addresses[3]
	 $gateway_server_ip = self.IP_addresses[4]
	 $server_ip         = self.IP_addresses[5]
	 $gateway_ext_ip    = self.IP_addresses[9]
	 $remote_ip         = self.IP_addresses[10]

	 $domain				   = self.domain
	 $dns_fix_flag     = self.dns_fix_flag
	 $vpn_connect_flag = self.vpn_connect_flag

	 def get_binding
		 binding
	 end %>

<?xml version="1.0"?>

<hackerbot
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.github/cliffe/SecGen/hackerbot">

	<name>Hackerbot</name>

	<AIML_chatbot_rules>config/AIML</AIML_chatbot_rules>

	<get_shell>ssh -i /opt/hackerbot/keys/id_rsa -oStrictHostKeyChecking=no root@<%= $desktop_ip %> /bin/bash</get_shell>

	<messages>
		<show_attack_numbers />
		<greeting>Welcome to the Secure Communications lab. Today you will be working with DNS security, TLS certificates, and VPNs. Let's get started!</greeting>
		<say_ready>Let me know when you are 'ready', if you want to move on say 'next', or 'previous'.</say_ready>
		<say_ready>When you are ready, simply say 'ready'.</say_ready>
		<say_ready>'Ready'?</say_ready>
		<say_ready>Better hurry... Let me know when you're 'ready'.</say_ready>
		<next>Ok, moving to the next challenge...</next>
		<next>Next challenge...</next>
		<next>Ok, onwards...</next>
		<previous>Ok, going back...</previous>
		<previous>Ok, previous challenge...</previous>
		<previous>Ok, backing up.</previous>
		<goto>Ok, skipping ahead.</goto>
		<goto>Let me see what I can do to goto that challenge.</goto>
		<last_attack>That was the last challenge for now. Well done! (End.)</last_attack>
		<last_attack>That was the last challenge. Great work!</last_attack>
		<first_attack>You are back to the beginning!</first_attack>
		<first_attack>This is where it all began.</first_attack>
		<getting_shell>Ok. Checking your configuration...</getting_shell>
		<getting_shell>Verifying...</getting_shell>
		<getting_shell>Let me check that...</getting_shell>
		<getting_shell>Here we go...</getting_shell>
		<got_shell>Connected to your system.</got_shell>
		<got_shell>Access confirmed.</got_shell>
		<got_shell>We have shell.</got_shell>
		<repeat>Let me know when you are 'ready', if you want to move on, say 'next', or 'previous'.</repeat>
		<repeat>Say 'ready', 'next', or 'previous'.</repeat>
		<help>I am waiting for you to say 'ready', 'next', 'previous', 'list', 'goto *X*', or 'answer *X*'</help>
		<say_answer>Say "The answer is X".</say_answer>
		<no_quiz>There is no question to answer</no_quiz>
		<correct_answer>Correct</correct_answer>
		<incorrect_answer>Incorrect</incorrect_answer>
		<invalid>That's not possible.</invalid>
		<non_answer>Wouldn't you like to know.</non_answer>
		<shell_fail_message>Oh no. Failed to connect... Check your network configuration.</shell_fail_message>
	</messages>

	<tutorial_info>
		<title>Secure Communications: VPNs, SSL/TLS and DNS Security</title>
		<tutorial><%= ERB.new(File.read self.templates_path + 'intro.md.erb').result(self.get_binding) %></tutorial>
		<footer>
<%= ERB.new(File.read self.templates_path + 'conclusion.md.erb').result(self.get_binding) %>
<%= ERB.new(File.read self.templates_path + 'resources.md.erb').result(self.get_binding) %>
<%= ERB.new(File.read self.templates_path + 'license.md.erb').result(self.get_binding) %>
Randomised instance generated by [SecGen](http://github.com/cliffe/SecGen) (<%= Time.new.to_s %>)
		</footer>
		<provide_tutorial>true</provide_tutorial>
	</tutorial_info>


	<!-- =================================================================
       CHALLENGE 1 - Zone transfer fix (config check)
       Hackerbot verifies AXFR is blocked and normal resolution still works
       Reveals dns_fix_flag on success
       ================================================================= -->

	<attack>
		<pre_shell>axfr_count=$(ssh -i /opt/hackerbot/keys/id_rsa -oStrictHostKeyChecking=no root@<%= $server_ip %> 'dig axfr <%= $domain %> @<%= $server_ip %> 2>/dev/null | grep -c "IN"'); dig_result=$(ssh -i /opt/hackerbot/keys/id_rsa -oStrictHostKeyChecking=no root@<%= $server_ip %> 'dig A web.<%= $domain %> @<%= $server_ip %> +short 2>/dev/null | grep -c "."'); echo AXFRCHECK-${axfr_count}-${dig_result}-</pre_shell>
		<get_shell>false</get_shell>
		<suppress_command_output_feedback />
		<prompt>The DNS server at <%= $server_ip %> is currently misconfigured to allow zone transfers from any host. Edit /etc/bind/named.conf.local on the server to restrict zone transfers, then reload bind9. Normal DNS resolution must still work. Say 'ready' when done.</prompt>
		<condition>
			<output_matches>AXFRCHECK-0-[1-9]-</output_matches>
			<message>:) Zone transfers are now restricted and normal DNS resolution still works. <%= $dns_fix_flag %></message>
			<trigger_next_attack>true</trigger_next_attack>
		</condition>
		<condition>
			<output_matches>AXFRCHECK-[1-9]-[1-9]-</output_matches>
			<message>:( Zone transfers are still permitted. Edit /etc/bind/named.conf.local on <%= $server_ip %> to disable the transfer. Make sure to reload your config after making changes.</message>
		</condition>
		<condition>
			<output_matches>AXFRCHECK-0-0-</output_matches>
			<message>:( Zone transfers are restricted but normal DNS resolution is broken. Check your named.conf.local and make sure the zone file is still correct, then run: sudo rndc reload</message>
		</condition>
		<else_condition>
			<message>:( Could not verify the DNS configuration. Make sure bind9 is running on <%= $server_ip %>.</message>
		</else_condition>
		<tutorial>
<%= ERB.new(File.read self.templates_path + 'dns_security.md.erb').result(self.get_binding) %>
		</tutorial>
	</attack>


	<!-- =================================================================
       CHALLENGE 2 - VPN connectivity (config check)
       Hackerbot verifies tun0 is up on gateway and remote can ping desktop
       Reveals vpn_connect_flag on success
       ================================================================= -->

	<attack>
		<pre_shell>tun_check=$(ssh -i /opt/hackerbot/keys/id_rsa -oStrictHostKeyChecking=no root@<%= $gateway_ext_ip %> 'ip link show tun0 > /dev/null; echo $?'); ping_check=$(ssh -i /opt/hackerbot/keys/id_rsa -oStrictHostKeyChecking=no root@<%= $remote_ip %> 'ping -c 1 -W 3 <%= $desktop_ip %> > /dev/null; echo $?'); echo VPNCHECK-${tun_check}-${ping_check}-</pre_shell>		<get_shell>false</get_shell>
		<suppress_command_output_feedback />
		<prompt>Start the OpenVPN server on the gateway (sudo openvpn --config /etc/openvpn/server/server.conf --daemon), then start the client on the remote VM (sudo openvpn --config /etc/openvpn/client/client.ovpn --daemon). Add FORWARD rules on the gateway to allow tun0 traffic into the internal network. Say 'ready' when the remote VM can ping the desktop at <%= $desktop_ip %>.</prompt>
		<condition>
			<output_matches>VPNCHECK-0-0-</output_matches>
			<message>:) The VPN tunnel is up and the remote VM can reach the internal network. <%= $vpn_connect_flag %></message>
			<trigger_next_attack>true</trigger_next_attack>
		</condition>
		<condition>
			<output_matches>VPNCHECK-0-[1-9]-</output_matches>
			<message>:( The tun0 interface exists on the gateway but the remote VM cannot reach the desktop. Check the FORWARD rules for tun0 on the gateway: sudo iptables -A FORWARD -i tun0 -j ACCEPT; sudo iptables -A FORWARD -o tun0 -j ACCEPT</message>
		</condition>
		<condition>
			<output_matches>VPNCHECK-[1-9]-[1-9]-</output_matches>
			<message>:( The tun0 interface does not exist on the gateway. Start the OpenVPN server: sudo openvpn --config /etc/openvpn/server/server.conf --daemon</message>
		</condition>
		<else_condition>
			<message>:( Could not verify VPN status. Make sure the gateway and remote VMs are reachable from the hackerbot server.</message>
		</else_condition>
		<tutorial>
<%= ERB.new(File.read self.templates_path + 'tls_certificates.md.erb').result(self.get_binding) %>

---

<%= ERB.new(File.read self.templates_path + 'vpn.md.erb').result(self.get_binding) %></tutorial>
	</attack>

</hackerbot>