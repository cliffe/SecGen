<?xml version="1.0"?>

<network xmlns="http://www.github/cliffe/SecGen/network"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://www.github/cliffe/SecGen/network">
  <name>Private Network</name>
  <author>Z. Cliffe Schreuders</author>
  <author>Tom Shaw</author>

  <module_license>GPLv3</module_license>
  <description>A network</description>

  <type>private_network</type>

  <read_fact>IP_address</read_fact>
  <read_fact>range</read_fact>
  <read_fact>vlan</read_fact>
  <read_fact>subnet_mask</read_fact>
  <read_fact>default_gateway</read_fact>
  <read_fact>dns_nameservers</read_fact>
  <read_fact>routes</read_fact>

  <default_input into="range">
    <generator type="random_ip_range"/>
  </default_input>

  <default_input into="vlan">
    <value>1</value>
  </default_input>

  <default_input into="subnet_mask">
    <value>255.255.255.0</value>
  </default_input>

</network>