<?xml version="1.0"?>

<utility xmlns="http://www.github/cliffe/SecGen/utility"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://www.github/cliffe/SecGen/utility">
  <name>iptables_rules</name>
  <author>Tom Shaw</author>
  <module_license>GPLv3</module_license>
  <description>Configures iptables rules using puppetlabs-firewall. Optionally enables IP forwarding.</description>

  <type>iptables_rule</type>
  <platform>linux</platform>

  <software_license>GPLv3</software_license>

  <read_fact>ip_forwarding</read_fact>
  <read_fact>rules</read_fact>

  <default_input into="ip_forwarding">
    <value>false</value>
  </default_input>

  <requires>
    <type>update</type>
  </requires>
</utility>