-module(ssh_daemon).
-export([start/1, shell/2]).

start(Port) ->
    io:format("Starting Erlang SSH daemon on port ~p~n", [Port]),
    
    KeyDir = "/opt/erlang_ssh/ssh_keys",
    case filelib:is_dir(KeyDir) of
        true -> ok;
        false ->
            os:cmd("mkdir -p " ++ KeyDir),
            os:cmd("ssh-keygen -t rsa -b 2048 -f " ++ KeyDir ++ "/ssh_host_rsa_key -N ''"),
            os:cmd("ssh-keygen -t ecdsa -b 256 -f " ++ KeyDir ++ "/ssh_host_ecdsa_key -N ''")
    end,
    
    {ok, _} = ssh:daemon(Port, [
        {system_dir, KeyDir},
        {shell, {fun shell/2, []}},
        {exec, {fun exec_cmd/1, []}},
        {auth_methods, "password,keyboard-interactive"},
        {user_passwords, [{"admin", "admin123"}]},
        {id_string, "Erlang/OTP SSH"},
        {bind_address, "0.0.0.0"}
    ]),
    io:format("SSH daemon started on port ~p~n", [Port]),
    timer:sleep(infinity).

shell(User, _Peer) ->
    io:format("Shell requested for user: ~p~n", [User]),
    {ok, S} = ssh_connection:shell(User),
    S.

exec_cmd(Cmd) ->
    io:format("Executing: ~p~n", [Cmd]),
    Result = os:cmd(Cmd),
    {ok, Result}.