<?xml version="1.0"?>

<scenario xmlns="http://www.github/cliffe/SecGen/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.github/cliffe/SecGen/scenario">

  <name>Network Examples: network_ip as module inputs</name>
  <author>Tom Shaw</author>
  <description>
    Demonstrates passing network_ip references directly into module inputs.

    Two VMs are defined on a single VLAN using default behaviour (random subnet,
    VLAN 1). The server runs an IRC daemon bound to its randomised IP. The desktop
    runs Pidgin configured to connect to that same IP.

    See networks_with_datastores.xml for the IP_addresses datastore pattern.
  </description>

  <system>
    <system_name>server</system_name>
    <base distro="Debian 12"/>

    <!-- IRC daemon bound to the server's randomised IP, resolved via network_ip -->
    <service type="ircd">
      <input into="ip">
        <network_ip system="server"/>
      </input>
    </service>

    <network type="private_network"/>

    <build type="cleanup">
      <input into="root_password">
        <value>toor</value>
      </input>
    </build>
  </system>

  <system>
    <system_name>desktop</system_name>
    <base distro="Debian 12" type="desktop" name="KDE"/>

    <!-- Pidgin configured to connect to the server's randomised IP -->
    <utility module_path=".*/pidgin">
      <input into="server_ip">
        <network_ip system="server"/>
      </input>
    </utility>

    <network type="private_network"/>

    <build type="cleanup">
      <input into="root_password">
        <value>toor</value>
      </input>
    </build>
  </system>

</scenario>