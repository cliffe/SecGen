<?xml version="1.0"?>

<scenario xmlns="http://www.github/cliffe/SecGen/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.github/cliffe/SecGen/scenario">

  <name>Network Examples: VLANs</name>
  <author>Tom Shaw</author>
  <description>
    Demonstrates multi-VLAN network configuration.

    Four VMs are defined across two VLANs:
    - desktop: VLAN 1, auto-assigned IP from a random subnet
    - server: VLAN 1, auto-assigned IP from the same subnet as desktop
    - gateway: VLAN 1 and VLAN 2 (multi-NIC) — bridges both networks
    - attacker: VLAN 2, auto-assigned IP from the same subnet as gateway's VLAN 2 interface

    VMs sharing a VLAN are placed on the same randomly generated subnet. The last
    octet is incremented per VM, where only the first VM on a VLAN needs to specify a
    range; subsequent VMs on the same VLAN inherit that subnet automatically.

    The gateway's VLAN 2 interface has an explicit IP range defined. The attacker is also on VLAN 2
    and gets an auto-assigned IP from the same subnet, skipping the octet already
    claimed by the gateway's assignment.

    The vlan attribute on network_ip selects the correct interface when referencing
    a VM with multiple NICs.
  </description>

  <system>
    <system_name>desktop</system_name>
    <base distro="Debian 12" type="desktop" name="KDE"/>

    <!--
      Explicit vlan only — subnet is randomly generated and shared by all
      other VMs on vlan 1 (server and gateway's first NIC).
    -->
    <network type="private_network">
      <input into="vlan">
        <value>1</value>
      </input>
    </network>

    <build type="cleanup">
      <input into="root_password">
        <value>toor</value>
      </input>
    </build>
  </system>

  <system>
    <system_name>server</system_name>
    <base distro="Debian 12" />

    <!--
      Same vlan as desktop — placed on the same random subnet, next available octet.
      No range input needed.
    -->
    <network type="private_network">
      <input into="vlan">
        <value>1</value>
      </input>
    </network>

    <build type="cleanup">
      <input into="root_password">
        <value>toor</value>
      </input>
    </build>
  </system>

  <system>
    <system_name>gateway</system_name>
    <base distro="Debian 12" />

    <!--
      VLAN 1 (default) interface: auto-assigned from the same subnet as desktop and server.
      Best practice is to define the vlans in multi-vlan scenarios for clarity, but this
      demonstrates interactions between the default behaviour and explicit definitions.
    -->
    <network type="private_network"/>

    <!--
      VLAN 2 interface: explicit range on a separate subnet.
      Specifying a range fixes the subnet while still auto-assigning the last
      octet. The attacker (also on vlan 2) will be placed on the same subnet
      with the next available octet, without needing to specify the range again.

      network_ip references to gateway must specify vlan="2" to select this
      interface rather than the VLAN 1 one.
    -->
    <network type="private_network">
      <input into="vlan">
        <value>2</value>
      </input>
      <input into="range">
        <value>10.10.0.0</value>
      </input>
    </network>

    <build type="cleanup">
      <input into="root_password">
        <value>toor</value>
      </input>
    </build>
  </system>

  <system>
    <system_name>attacker</system_name>
    <base distro="Kali" name="MSF"/>

    <!--
      VLAN 2 only — placed on the same subnet as gateway's VLAN 2 interface
      (10.10.0.0), with the next available octet (.3 - after skipping .2 which was claimed
      by the gateway).
    -->
    <network type="private_network">
      <input into="vlan">
        <value>2</value>
      </input>
    </network>

    <build type="cleanup">
      <input into="root_password">
        <value>toor</value>
      </input>
    </build>
  </system>

</scenario>