<?xml version="1.0"?>

<scenario xmlns="http://www.github/cliffe/SecGen/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.github/cliffe/SecGen/scenario">

  <name>Network Examples: IP_addresses datastore</name>
  <author>Tom Shaw</author>
  <description>
    Demonstrates using network_ip tags to populate the IP_addresses datastore,
    which is then consumed by a module that requires the full list of scenario IPs.

    This is a convenient pattern when a module needs all scenario IPs passed in
    as a list. The hosts utility is a good example — it requires a matching list
    of hostnames and IP addresses to write /etc/hosts entries across all VMs.
    Declaring the IPs once in a central datastore avoids repeating network_ip
    tags throughout the scenario.

    For individual IP lookups, network_ip tags are used directly rather than
    datastore index lookups.

    Two VMs are defined using default behaviour (random subnet, VLAN 1).
  </description>

  <system>
    <system_name>server</system_name>
    <base distro="Debian 12"/>

    <!--
      Central IP_addresses datastore populated with network_ip references.
      Use this when a module requires the full ordered list of IPs as input.

      [0] server  (this VM)
      [1] desktop
    -->
    <input into_datastore="IP_addresses">
      <network_ip system="server"/>
      <network_ip system="desktop"/>
    </input>

    <!--
      The hosts utility requires a matching list of hostnames and IPs to
      write /etc/hosts entries. The full IP_addresses datastore is passed
      in as a list to match the hostnames list positionally.
    -->
    <utility module_path=".*/hosts">
      <input into="hosts">
        <value>server</value>
        <value>desktop</value>
      </input>
      <input into="IP_addresses">
        <datastore>IP_addresses</datastore>
      </input>
    </utility>

    <!--
      For a single IP, use network_ip directly rather than a datastore index lookup.
    -->
    <service type="ircd">
      <input into="ip">
        <network_ip system="server"/>
      </input>
    </service>

    <network type="private_network"/>

    <build type="cleanup">
      <input into="root_password">
        <value>toor</value>
      </input>
    </build>
  </system>

  <system>
    <system_name>desktop</system_name>
    <base distro="Debian 12" type="desktop" name="KDE"/>

    <!-- Same hosts entries on the desktop, consuming the shared datastore -->
    <utility module_path=".*/hosts">
      <input into="hosts">
        <value>server</value>
        <value>desktop</value>
      </input>
      <input into="IP_addresses">
        <datastore>IP_addresses</datastore>
      </input>
    </utility>

    <!-- network_ip used directly for a single IP lookup -->
    <utility module_path=".*/pidgin">
      <input into="server_ip">
        <network_ip system="server"/>
      </input>
    </utility>

    <network type="private_network"/>

    <build type="cleanup">
      <input into="root_password">
        <value>toor</value>
      </input>
    </build>
  </system>

</scenario>