    <!-- =====================================================================
     GATEWAY — multi-homed router/firewall
     Interfaces:
       eth1: 10.0.1.1/24  (internal LAN)
       eth2: 10.0.2.1/24  (DMZ)
     Responsibilities:
       - IP forwarding between segments
       - iptables FILTER rules enforcing segmentation (with intentional
         misconfiguration for Challenge 3, fixed by students in Challenge 5/6)
       - iptables NAT rules: MASQUERADE for outbound, DNAT for Challenge 4
       - iptables comment embedding a flag (Challenge 2)
     ===================================================================== -->

    <system>
        <system_name>gateway</system_name>
        <base distro="Debian 12" type="desktop"/>

        <!-- Store all scenario IPs in a shared datastore for cross-VM references -->
        <input into_datastore="IP_addresses">
            <!-- [0] gateway LAN-side -->
            <value>10.0.1.1</value>
            <!-- [1] workstation -->
            <value>10.0.1.10</value>
            <!-- [2] server -->
            <value>10.0.1.20</value>
            <!-- [3] gateway DMZ-side -->
            <value>10.0.2.1</value>
            <!-- [4] webserver -->
            <value>10.0.2.10</value>
        </input>

        <input into_datastore="spoiler_admin_pass">
            <value>tiaspbiqe2r</value>
<!--            <generator type="strong_password_generator"/>-->
        </input>

        <utility module_path=".*/parameterised_accounts">
            <input into="accounts" into_datastore="account">
                <generator type="account">
                    <input into="username">
                        <generator type="username_generator"/>
                    </input>
                    <input into="password">
                        <value>tiaspbiqe2r</value>
                    </input>
                    <input into="super_user">
                        <value>true</value>
                    </input>
                </generator>
            </input>
        </utility>


