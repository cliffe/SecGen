<?xml version="1.0"?>

<scenario xmlns="http://www.github/cliffe/SecGen/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.github/cliffe/SecGen/scenario">

    <name>Network Security Fundamentals</name>
    <author>Tom Shaw</author>
    <description>
        Network security fundamentals lab covering network design, segmentation,
        NAT, DMZ, and firewalls. Students connect a three-segment network,
        investigate firewall rules, discover misconfigurations, and build
        segmentation policies using iptables.
    </description>
    <lab_sheet_url>https://cliffe.github.io/HacktivityLabSheets/labs/network_security/1-intro-network-security/</lab_sheet_url>

    <type>ctf-lab</type>
    <type>lab-sheet</type>
    <difficulty>intermediate</difficulty>

    <CyBOK KA="NS" topic="Network Security Fundamentals">
        <keyword>NETWORK SEGMENTATION</keyword>
        <keyword>DEMILITARISED ZONE (DMZ)</keyword>
        <keyword>NETWORK ADDRESS TRANSLATION (NAT)</keyword>
        <keyword>FIREWALLS</keyword>
        <keyword>IPTABLES</keyword>
        <keyword>DEFAULT DENY</keyword>
    </CyBOK>

    <CyBOK KA="NS" topic="Network Defence">
        <keyword>perimeter security</keyword>
        <keyword>firewall configuration</keyword>
        <keyword>stateful packet inspection</keyword>
    </CyBOK>


    <!-- =================================================================
         SHARED DATASTORE — IP addresses
         =================================================================
         Index  IP             Host / Interface
         [0]    10.0.1.1       gateway — Internal LAN side  (VLAN 1)
         [1]    10.0.1.10      desktop                       (VLAN 1)
         [2]    10.0.2.1       gateway — DMZ side            (VLAN 2)
         [3]    10.0.2.10      webserver                     (VLAN 2)
         [4]    10.0.3.1       gateway — Server zone side    (VLAN 3)
         [5]    10.0.3.10      server                        (VLAN 3)
         ================================================================= -->


    <!-- =================================================================
         DESKTOP — student starting point
         Segment: Internal LAN (10.0.1.0/24) — VLAN 1
         Software: nmap, wireshark, handy CLI tools
         ================================================================= -->

    <system>
        <system_name>desktop</system_name>
        <base platform="linux" distro="Debian 12" type="desktop" name="KDE"/>

        <!-- Shared IP datastore — defined here on the first system -->
        <input into_datastore="IP_addresses">
            <!-- [0] gateway — Internal LAN side -->
            <value>10.0.1.1</value>
            <!-- [1] desktop -->
            <value>10.0.1.10</value>
            <!-- [2] gateway — DMZ side -->
            <value>10.0.2.1</value>
            <!-- [3] webserver -->
            <value>10.0.2.10</value>
            <!-- [4] gateway — Server zone side -->
            <value>10.0.3.1</value>
            <!-- [5] server -->
            <value>10.0.3.10</value>
        </input>

        <input into_datastore="spoiler_admin_pass">
            <value>tiaspbiqe2r</value>
        </input>

        <utility module_path=".*/parameterised_accounts">
            <input into="accounts" into_datastore="account">
                <generator type="account">
                    <input into="username">
                        <generator type="username_generator"/>
                    </input>
                    <input into="password">
                        <value>tiaspbiqe2r</value>
                    </input>
                    <input into="super_user">
                        <value>true</value>
                    </input>
                </generator>
            </input>
        </utility>

        <utility module_path=".*/handy_cli_tools"/>
        <utility module_path=".*/nmap"/>
        <utility module_path=".*/wireshark"/>

        <!-- Internal LAN interface (VLAN 1) -->
        <network type="private_network">
            <input into="IP_address">
                <datastore access="1">IP_addresses</datastore>
            </input>
            <input into="vlan">
                <value>1</value>
            </input>
        </network>

        <build type="cleanup">
            <input into="root_password">
                <datastore>spoiler_admin_pass</datastore>
            </input>
        </build>

    </system>


    <!-- =================================================================
         GATEWAY — multi-homed router/firewall
         Segments: Internal LAN (VLAN 1), DMZ (VLAN 2), Server zone (VLAN 3)
         Responsibilities:
           - IP forwarding between segments (students enable this)
           - iptables FILTER rules enforcing segmentation (with intentional
             misconfiguration for Challenge 3, fixed by students in Ch 4/6)
           - iptables NAT rules: MASQUERADE for outbound, DNAT for Ch 5
         ================================================================= -->

    <system>
        <system_name>gateway_server</system_name>
        <base platform="linux" distro="Debian 12" type="desktop"/>

        <utility module_path=".*/parameterised_accounts">
            <input into="accounts">
                <datastore>account</datastore>
            </input>
        </utility>

        <!--        <utility module_path=".*iptables_netsec_gateway">-->
        <!--            <input into="lan_network">-->
        <!--                <value>10.0.1.0/24</value>-->
        <!--            </input>-->
        <!--            <input into="dmz_network">-->
        <!--                <value>10.0.2.0/24</value>-->
        <!--            </input>-->
        <!--            <input into="server_network">-->
        <!--                <value>10.0.3.0/24</value>-->
        <!--            </input>-->
        <!--            <input into="server_ip">-->
        <!--                <datastore access="5">IP_addresses</datastore>-->
        <!--            </input>-->
        <!--            <input into="webserver_ip">-->
        <!--                <datastore access="3">IP_addresses</datastore>-->
        <!--            </input>-->
        <!--            <input into="misconfigured_port">-->
        <!--                <datastore access="0">challenge3_port</datastore>-->
        <!--            </input>-->
        <!--            <input into="dnat_external_port">-->
        <!--                <datastore access="0">challenge5_external_port</datastore>-->
        <!--            </input>-->
        <!--            <input into="dnat_internal_port">-->
        <!--                <datastore access="0">challenge5_internal_port</datastore>-->
        <!--            </input>-->
        <!--        </utility>-->

        <!-- Internal LAN interface (VLAN 1) -->
        <network type="private_network">
            <input into="IP_address">
                <datastore access="0">IP_addresses</datastore>
            </input>
            <input into="vlan">
                <value>1</value>
            </input>
        </network>

        <!-- DMZ interface (VLAN 2) -->
        <network type="private_network">
            <input into="IP_address">
                <datastore access="2">IP_addresses</datastore>
            </input>
            <input into="vlan">
                <value>2</value>
            </input>
        </network>

        <!-- Server zone interface (VLAN 3) -->
        <network type="private_network">
            <input into="IP_address">
                <datastore access="4">IP_addresses</datastore>
            </input>
            <input into="vlan">
                <value>3</value>
            </input>
        </network>

        <build type="cleanup">
            <input into="root_password">
                <datastore>spoiler_admin_pass</datastore>
            </input>
        </build>

    </system>


    <!-- =================================================================
         WEBSERVER — DMZ host
         Segment: DMZ (10.0.2.0/24) — VLAN 2
         Runs apache on port 80. Also has nmap and wireshark so students
         can run scans from the DMZ perspective (Challenge 3).
         Contains a flag file in the user home directory (Challenge 2).
         ================================================================= -->

    <system>
        <system_name>webserver</system_name>
        <base platform="linux" distro="Debian 12" type="desktop"/>

        <utility module_path=".*/parameterised_accounts">
            <input into="accounts">
                <datastore>account</datastore>
            </input>
        </utility>

        <service module_path=".*/apache"/>
        <utility module_path=".*/nmap"/>
        <utility module_path=".*/wireshark"/>

        <!-- TODO: Place a randomised flag in /home/<user>/flag.txt (Challenge 2) -->

        <!-- DMZ interface (VLAN 2) -->
        <network type="private_network">
            <input into="IP_address">
                <datastore access="3">IP_addresses</datastore>
            </input>
            <input into="vlan">
                <value>2</value>
            </input>
        </network>

        <build type="cleanup">
            <input into="root_password">
                <datastore>spoiler_admin_pass</datastore>
            </input>
        </build>

    </system>


    <!-- =================================================================
         SERVER — internal server
         Segment: Server zone (10.0.3.0/24) — VLAN 3
         Runs:
           - Challenge 3: TCP banner service on a randomised port
                          (intentionally reachable from DMZ — the misconfiguration)
           - Challenge 5: TCP banner service on a randomised internal port,
                          exposed via DNAT rule on gateway
         ================================================================= -->

    <system>
        <system_name>server</system_name>
        <base platform="linux" distro="Debian 12" type="desktop"/>

        <utility module_path=".*/parameterised_accounts">
            <input into="accounts">
                <datastore>account</datastore>
            </input>
        </utility>

        <utility module_path=".*/wireshark"/>

        <!-- TODO: Add flag-returning services for Challenges 3 and 5 -->

        <!-- Server zone interface (VLAN 3) -->
        <network type="private_network">
            <input into="IP_address">
                <datastore access="5">IP_addresses</datastore>
            </input>
            <input into="vlan">
                <value>3</value>
            </input>
        </network>

        <build type="cleanup">
            <input into="root_password">
                <datastore>spoiler_admin_pass</datastore>
            </input>
        </build>

    </system>

</scenario>