        </build>

    </system>

    <!-- =====================================================================
         WEBSERVER — DMZ host
         Runs apache on port 80. Also has nmap, tcpdump + wireshark so students
         can run scans from the DMZ perspective (Challenges 3 and 6).
         ===================================================================== -->

    <system>
        <system_name>webserver</system_name>
        <base distro="Debian 12" type="desktop"/>

        <utility module_path=".*/parameterised_accounts">
            <input into="accounts">
                <datastore>account</datastore>
            </input>
        </utility>

        <service module_path=".*/apache"/>
        <utility module_path=".*/nmap"/>
        <utility module_path=".*/wireshark"/>


        <network type="private_network">
            <input into="IP_address">
                <datastore access="4">IP_addresses</datastore>
            </input>
        </network>

        <build type="cleanup">
            <input into="root_password">
                <datastore>spoiler_admin_pass</datastore>
            </input>
        </build>

