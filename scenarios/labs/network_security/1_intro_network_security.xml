           - Challenge 4: TCP banner service on a randomised internal port,
                          exposed via DNAT rule on gateway
         ===================================================================== -->

    <system>
        <system_name>server</system_name>
        <base distro="Debian 12" type="desktop"/>

        <!-- TODO: REMOVE/MODIFY ME WHEN WE ADD CHALLENGES -->
